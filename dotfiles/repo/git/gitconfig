[alias]
    # https://git.wiki.kernel.org/articles/a/l/i/Aliases.html

    # Checkout shorcut
    co = checkout

    # Note this requires some custom config
    # See: https://gist.github.com/piscisaureus/3342247
    copr = "!f() { git checkout upstream/pr/$1 && git checkout -b pr/$1; }; f"

    # List remotes
    remotes = remote -v

    # List branches
    branches = branch -ra -vv

    # Handy commit shortcuts
    c =  commit
    save = commit -m "stash"
    redo = commit -a --amend --no-edit
    rewrite = commit --amend

    # Commit with scope / message shortcuts
    # Remember to quote $2 if it contains spaces
    #
    # Usage:
    # git <alias> <scope> "<Commit Message>"
    #
    # Example:
    # git chore docs "Update README.md"
    chore = "!f() { git commit -m \"chore($1): $2\";  }; f"
    fix = "!f() { git commit -m \"fix($1): $2\";  }; f"
    hotfix = "!f() { git commit -m \"hotfix($1): $2\";  }; f"
    refactor = "!f() { git commit -m \"refactor($1): $2\";  }; f"
    feature = "!f() { git commit -m \"feature($1): $2\";  }; f"

    # Push shortcuts
    # $() returns current branch name
    push-topic = !git push -u origin $(git rev-parse --abbrev-ref HEAD)
    ramrod = push -f

    # Re-base shortcuts
    rbo = "!f() { git rebase origin/$1; }; f"
    rbu = "!f() { git rebase upstream/$1; }; f"

    # Interactive
    addi = add -i
    rbi = "!f() { git rebase -i $1^; }; f"

    # Mergetool shortcut
    resolve = mergetool

    # stash shortcuts
    unstash = !git stash pop

    # `git remote prune origin`: remove remote-tracking branches that were deleted from the remote repo
    # `git gc`: cleanup unnecessary files and optimize the local repository
    # `git clean -df`: remove untracked files and directories from the working tree
    # `git stash clear`: remove all stashed states
    trim = !git remote prune origin && git gc
    cleanup = !git clean -df && git stash clear

    # Add untracked, remove deleted, and show status
    all = !git add -A && git status

    # Remove all staged files
    none = !git reset && git status

    # Diff what is staged for the next commit
    diffc = diff --cached

    # Diff overview
    diffst = diff --stat

    # Custom graph log (append any tree-ish)
    lg = log --pretty=nice --date-order --graph

    # Custom graph log for all branches
    lga = log --pretty=nice --date-order --graph --all

    # Custom pretty log
    ls = log --pretty=nice --date-order

    # Custom pretty log long format
    ll = log --pretty=nice --decorate --numstat

    # Short format diffstat log
    lsd = log --stat --format=oneline --abbrev-commit

    # Diffstat log
    lld = log --stat

    # Find out who is currently active on the repository
    # Displays committers in descending order of number of commits
    who = shortlog --numbered --summary --email --no-merges

    tags = tag -l

    clean-orig = "!f() { find . -name \"*.orig\" -delete; }; f"

    copr = "!f() { git checkout refs/pull/upstream/$1; }; f"

[color]
    # color opts: normal, black, red, green, yellow, blue, magenta, cyan, or white
    ui = auto
    interactive = auto

[core]
    # Use custom `.gitignore` and `.gitattributes`
    excludesfile = ~/.gitignore
    attributesfile = ~/.gitattributes

[credential]
    helper = osxkeychain

[diff]
    # Default settings, I usually install Kaleidoscope which will update this file/entry
    tool = mvimdiff

[difftool]
    prompt = false

[pretty]
    # tut: http://gitimmersion.com/lab_10.html
    # ref: http://linux.die.net/man/1/git-log
    # Result: <short-sha> <commit-message> (<pointer-names>) -- <commit-author-name>; <relative-time>
    nice = "%C(yellow)%h%C(reset) %C(white)%s%C(cyan)%d%C(reset) -- %an; %ar"

[push]
    default = tracking
